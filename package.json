{
  "name": "@insightop/libopenblt",
  "version": "0.2.1",
  "description": "TypeScript implementation of the OpenBLT host library for XCP-based firmware updates over Modbus RTU",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/insightop/libopenblt.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "openblt",
    "xcp",
    "ota",
    "modbus",
    "firmware-update",
    "bootloader",
    "stm32"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "release": "npm publish --provenance --access public",
    "clean": "rm -rf dist .tsbuildinfo",
    "prepublishOnly": "npm run build && npm run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "pkg-pr-new": "^0.0.75",
    "tsup": "^8.5.1",
    "typescript": "~5.6.2",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0"
  }
}
